// QANTM Media Portal — data model (Build Plan §07).
// SQLite runs in every environment (dev, test, prod) for a single-operator
// deployment — WAL mode + Litestream give durability (see docs/DEPLOYMENT.md).
// Kept portable anyway: no enums, string status fields validated at the app
// layer, so a future move to Postgres stays low-friction.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  totpSecret   String? // set during 2FA enrollment; login requires it confirmed
  totpEnabled  Boolean  @default(false)
  totpLastStep BigInt? // last accepted TOTP time-step — blocks code replay
  createdAt    DateTime @default(now())

  accounts      SocialAccount[]
  posts         Post[]
  assets        Asset[]
  audits        AuditEvent[]
  categories    Category[]
  credentials   Credential[]
  notifications Notification[]
  feedSources   FeedSource[]
}

// An operator-added RSS/Atom feed the trending surface polls. No third-party
// keys — just public feed URLs the operator chooses. Free and real.
model FeedSource {
  id            String    @id @default(cuid())
  userId        String
  url           String
  title         String // feed's own <title>, captured on add
  enabled       Boolean   @default(true)
  lastFetchedAt DateTime?
  lastError     String? // last poll failure, surfaced in Settings
  createdAt     DateTime  @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items FeedItem[]

  @@unique([userId, url])
  @@index([userId, enabled])
}

// One item pulled from a feed. Deduped per source by guid (falls back to the
// link). Pruned to a recent window by the poller.
model FeedItem {
  id          String    @id @default(cuid())
  sourceId    String
  guid        String // <guid>/<id>, or the link when absent
  title       String
  link        String
  summary     String? // short text, HTML stripped
  publishedAt DateTime? // item's own date, where present
  fetchedAt   DateTime  @default(now())

  source FeedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, guid])
  @@index([sourceId, publishedAt])
}

// Operator notifications, created by real events (a permanent publish failure,
// Autopilot drafting posts for review, …). In-app is the source of truth;
// email is an optional mirror sent when SMTP is configured and the operator
// opted in. Never contains secrets.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // publish_failed | review_ready (extensible)
  level     String    @default("info") // info | warn | error
  title     String
  body      String
  link      String? // in-app route to open, e.g. /dashboard
  read      Boolean   @default(false)
  emailedAt DateTime? // set when an email mirror was sent (null = in-app only)
  metadata  String? // JSON; never secrets
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

// Operator-supplied API keys (e.g. Anthropic), encrypted at rest with the same
// AES-256-GCM vault as OAuth tokens. Write-only: the ciphertext and plaintext
// never go to the client — only `hint` (last 4 chars) is returned, for masked
// display. One key per provider per operator.
model Credential {
  id           String    @id @default(cuid())
  userId       String
  provider     String // "anthropic" (extensible)
  ciphertext   String // base64: iv · authTag · ciphertext (vault format)
  keyVersion   Int       @default(1)
  hint         String // last 4 chars of the key — non-sensitive, for masking
  lastTestedAt DateTime? // last "Test key" run
  lastTestOk   Boolean? // result of that run
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// Content categories — per operator, editable (create/rename/recolor/delete).
// Posts reference a category by NAME (a plain string on Post), not by FK: a
// deleted category must never cascade-delete posting history, and a rename
// updates existing posts explicitly. Defaults are seeded on first use.
model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String // hex, drives the calendar "category" lens
  hashtags  String? // comma-joined suggestion list for the composer
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, sortOrder])
}

// One row per encrypted credential. AES-256-GCM envelope encryption; the
// master key is env-provided locally and KMS-managed in production.
// Tokens never leave the server, are never logged, never sent to the client.
model VaultSecret {
  id         String   @id @default(cuid())
  ciphertext String // base64: iv · authTag · ciphertext
  keyVersion Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account SocialAccount?
}

model SocialAccount {
  id         String    @id @default(cuid())
  userId     String
  platform   String // instagram | facebook | x | linkedin | youtube | tiktok | threads | bluesky | pinterest | gbp
  externalId String // platform-side id (page id, IG business id, …)
  name       String // platform display name, e.g. "Instagram"
  mark       String // short mark, e.g. "IG"
  handle     String // @handle or page/profile label
  label      String? // user-set label to tell same-platform accounts apart
  scopes     String? // granted OAuth scopes, comma-joined
  status     String    @default("disconnected") // connected | expiring | paused | disconnected
  expiresAt  DateTime?
  tokenRef   String?   @unique // -> VaultSecret
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  token   VaultSecret?  @relation(fields: [tokenRef], references: [id])
  targets PostTarget[]

  @@unique([platform, externalId])
  @@index([userId, platform])
}

model Asset {
  id         String   @id @default(cuid())
  userId     String
  type       String // image | video
  status     String   @default("ready") // ready | processing | failed — videos transcode async in the worker
  storageKey String // object-storage key; files never live in the DB
  filename   String
  mime       String?
  width      Int?
  height     Int?
  durationS  Float? // video duration
  coverKey   String? // video cover frame storage key
  processingStartedAt DateTime? // transcode claim marker — prevents double processing
  variants   String? // JSON: generated crops/transcodes/renditions
  error      String? // processing failure reason
  createdAt  DateTime @default(now())
  tags       String? // comma-joined

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Post {
  id          String   @id @default(cuid())
  userId      String
  baseCaption String
  category    String   @default("Promo")
  status      String   @default("draft") // draft | scheduled | published | failed
  source      String   @default("manual") // manual | autopilot
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  targets PostTarget[]
}

model PostTarget {
  id              String    @id @default(cuid())
  postId          String
  socialAccountId String
  captionOverride String?
  assetIds        String? // comma-joined Asset ids
  scheduledAt     DateTime?
  state           String    @default("draft") // draft | scheduled | publishing | published | failed | cancelled
  permalink       String?
  externalMediaId String? // platform-side media/post id — required for insights pulls; "mock_…" for mock publishes
  error           String?

  post    Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  account SocialAccount    @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  jobs    PublishJob[]
  metrics MetricSnapshot[]

  @@index([state, scheduledAt])
}

// One insights pull for one published target — a time series, so growth is
// computable and a bad pull never destroys history. Only ever written from
// REAL platform API responses; mock publishes get no rows.
model MetricSnapshot {
  id           String   @id @default(cuid())
  postTargetId String
  fetchedAt    DateTime @default(now())
  views        Int? // platform "views" (Meta's current unified metric)
  reach        Int? // unique accounts reached, where the platform reports it
  likes        Int?
  comments     Int?
  shares       Int?
  saves        Int?
  raw          String // full API response for audit/forward-compat

  target PostTarget @relation(fields: [postTargetId], references: [id], onDelete: Cascade)

  @@index([postTargetId, fetchedAt])
}

model PublishJob {
  id           String    @id @default(cuid())
  postTargetId String
  runAt        DateTime
  attempts     Int       @default(0)
  lastError    String?
  claimedAt    DateTime? // atomic claim marker — prevents double-publish across workers
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  target PostTarget @relation(fields: [postTargetId], references: [id], onDelete: Cascade)

  @@index([runAt, completedAt])
}

// Operator-level flags (kill switch, autopilot). Single-row-per-key KV.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditEvent {
  id        String   @id @default(cuid())
  userId    String?
  action    String // auth.login | auth.login.failed | auth.verify | auth.setup | account.connect | account.disconnect | account.pause | account.resume | publish.* …
  ip        String?
  metadata  String? // JSON; never contains secrets
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
}
