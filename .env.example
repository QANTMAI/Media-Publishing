# ─────────────────────────────────────────────────────────────────────────
# QANTM Media Portal — environment. Copy to .env for local dev.
# DO NOT COMMIT a filled-in .env. Production uses a secrets manager, not a file.
# The app validates this at boot (src/lib/server/config.ts) and, in production,
# refuses to start if a security-critical value is missing or weak.
#
# Generate the three base64 secrets with:
#   openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────

# Database. Dev = SQLite (zero-setup). Production = Postgres:
#   DATABASE_URL="postgresql://user:pass@host:5432/qantm?schema=public"
# (Switching to Postgres also needs the Prisma provider change — see docs/DEPLOYMENT.md.)
DATABASE_URL="file:./dev.db"

# 32-byte secrets. Rotate for production; in prod, VAULT_MASTER_KEY is the
# KMS-managed master key that wraps the vault.
SESSION_SECRET=""          # JWT session signing key (>= 32 chars)
VAULT_MASTER_KEY=""        # AES-256-GCM master key — MUST decode to exactly 32 bytes
STORAGE_SIGNING_KEY=""     # signs expiring media URLs (>= 32 bytes)

# Media storage (T-106): private files served only via signed expiring URLs.
STORAGE_DIR="storage"
PUBLIC_ORIGIN=""           # e.g. https://portal.example.com — REQUIRED in prod (signed media / real IG publishing)

# Meta (Instagram + Facebook + Threads share one app) — fill in after app review.
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI=""       # https://<PUBLIC_ORIGIN>/api/oauth/meta/callback

# With no Meta app configured, the connect flow runs in clearly-labeled MOCK
# mode so the UI is testable end-to-end. Set to 0 for real OAuth (then the
# META_* values above are required).
OAUTH_MOCK="1"

# Email notifications (optional). Set BOTH to enable; leave BOTH empty to
# disable (the app then records notifications in-app only and says so).
#   SMTP_URL="smtps://user:pass@smtp.example.com:465"
SMTP_URL=""
SMTP_FROM=""               # e.g. "QANTM Media <no-reply@example.com>"

# Trust the X-Forwarded-For header for audit IPs. Set to 1 ONLY behind a proxy
# you control that overwrites the header — otherwise audit IPs are spoofable.
TRUST_PROXY=""

# Dev-only 2FA bypass (non-production only). 1 = enable /api/auth/dev-login.
# MUST be unset in production — the config guard aborts the boot if it's on.
AUTH_DEV_BYPASS=""

# Note: AI provider keys (Anthropic) are NOT env vars — the operator adds them
# in-app under Settings → Integrations & keys, stored encrypted in the vault.
