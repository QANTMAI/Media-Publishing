# Local development environment — DO NOT COMMIT. Production uses a secrets manager.
DATABASE_URL="file:./dev.db"

# 32-byte base64 secrets (generated for this machine). Rotate for production;
# VAULT_MASTER_KEY is the KMS-managed master key in prod.
SESSION_SECRET=""
VAULT_MASTER_KEY=""

# Meta (Instagram + Facebook + Threads share one app) — fill in after app review.
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI=""

# With no Meta app configured, the connect flow runs in clearly-labeled mock
# mode so the UI is testable end-to-end. Set to 0 to force real OAuth.
OAUTH_MOCK="1"

# Media storage (T-106): private files served only via signed expiring URLs.
STORAGE_DIR="storage"
STORAGE_SIGNING_KEY=""
PUBLIC_ORIGIN=""  # e.g. https://portal.example.com — required for real Instagram media publishing
